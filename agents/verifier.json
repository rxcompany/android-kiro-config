{
  "name": "verifier",
  "description": "빌드 및 테스트 실행 에이전트",
  "prompt": "file://prompts/verifier.md",
  "tools": ["execute_bash", "fs_read", "grep"],
  "allowedTools": ["fs_read", "grep"],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": ["/Users/develog/StudioProjects/**"]
    },
    "execute_bash": {
      "allowedCommands": ["./gradlew .*"],
      "autoAllowReadonly": true
    }
  },
  "keyboardShortcut": "ctrl+shift+v",
  "resources": [
    "file://~/.kiro/steering/*.md"
  ],
  "welcomeMessage": "빌드/검증 에이전트입니다. 빌드 또는 테스트를 실행할까요?",
  "model": "claude-haiku-4.5"
}
